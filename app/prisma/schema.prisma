generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// カテゴリ (事業A, 事業B, 全体, プライベート)
model Category {
  id                 String   @id @default(cuid())
  name               String
  excludeFromSummary Boolean  @default(false)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  timeEntries TimeEntry[]
}

// ジャンル (1on1, MTG, 開発, プロジェクト, 思考, 対話, ルーティン)
model Genre {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  type      String   @default("経費")
  subType   String   @default("")          // "投資的" | "経費的" | ""(付随)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries TimeEntry[]
}

// 時間記録
model TimeEntry {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  startSlot  Int      // 0-47 (30分刻み、0=0:00, 1=0:30, ...)
  endSlot    Int      // 0-47 (開始の次以降)
  categoryId String
  genreId    String
  title      String?
  detail     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 繰り返し設定（親エントリのみ）
  recurrenceRule String?   // JSON: { type, interval?, customUnit?, daysOfWeek? }
  recurrenceEnd  DateTime? @db.Date

  // オーバーライド/例外（子エントリのみ）
  parentRecurrenceId String?
  originalDate       DateTime? @db.Date // 本来の発生日
  skipped            Boolean   @default(false) // true = この回はキャンセル

  category         Category   @relation(fields: [categoryId], references: [id])
  genre            Genre      @relation(fields: [genreId], references: [id])
  parentRecurrence TimeEntry? @relation("RecurrenceOverrides", fields: [parentRecurrenceId], references: [id])
  overrides        TimeEntry[] @relation("RecurrenceOverrides")
}

// 家計簿カテゴリ
model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6b7280")
  icon      String   @default("default")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses      Expense[]
  fixedExpenses FixedExpense[]
}

// 家計簿
model Expense {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  amount     Int
  type       String   @default("expense") // "expense" or "income"
  categoryId String?
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

// 固定費
model FixedExpense {
  id         String   @id @default(cuid())
  title      String
  amount     Int
  type       String   @default("expense") // "expense" or "income"
  categoryId String?
  day        Int      @default(1) // 毎月の引落日
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

// 一言日記
model DailyNote {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 筋トレメニューマスタ
model ExerciseMenu {
  id            String   @id @default(cuid())
  name          String
  defaultWeight String   @default("")
  defaultReps   Int      @default(10)
  defaultSets   Int      @default(3)
  type          String   @default("strength") // "strength" | "running"
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 筋トレ記録
model WorkoutLog {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  exercises Json     // [{menuId?, name, weight, reps, sets, type, distance?, duration?, pace?}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 本マスタ（旧スキーマ。Book に移行中。次PRで削除予定）
model BookTitle {
  id        String   @id @default(cuid())
  title     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readingLogs ReadingLog[]
}

// 漫画シリーズ等の書籍まとめ
model BookSeries {
  id        String   @id @default(cuid())
  name      String   @unique
  author    String?
  coverUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]
}

// 書籍/記事 (Kindle / 紙 / 漫画 / Web 記事 / PDF を統合)
model Book {
  id          String    @id @default(cuid())
  title       String
  author      String?
  coverUrl    String?
  source      String    @default("kindle") // "kindle" | "paper" | "manga" | "web" | "pdf"
  asin        String?   @unique             // Kindle 突合キー
  isbn        String?
  publisher   String?
  url         String?   @unique             // Web 記事の URL (source="web") / 突合キー兼用
  excerpt     String?                       // 記事冒頭・要約
  siteName    String?                       // og:site_name 等
  publishedAt DateTime?                     // 記事公開日
  rating      Int? // 1-5
  purchasedAt DateTime? @db.Date
  finishedAt  DateTime? @db.Date
  seriesId    String?
  volume      Int? // 漫画の巻数
  notes       String?
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  series      BookSeries?  @relation(fields: [seriesId], references: [id])
  highlights  Highlight[]
  bookmarks   Bookmark[]
  readingLogs ReadingLog[] @relation("BookReadingLogs")

  @@index([seriesId])
  @@index([source])
}

// ハイライト（テキスト / 図表 / 自分のメモ）
model Highlight {
  id            String    @id @default(cuid())
  bookId        String
  type          String    @default("text") // "text" | "image" | "note"
  text          String? // ハイライト本文（image なら caption）
  note          String? // App 側のメモ (アプリ専用、同期で触らない)
  kindleNote    String? // Kindle 側のメモ (同期のたびに上書きされる)
  color         String? // yellow | blue | pink | orange
  location      String? // 例: "位置No. 1234"
  page          Int?
  imageUrl      String? // 図表ハイライトの画像URL
  highlightedAt DateTime?
  externalId    String? // Amazon の一意キー（重複排除用）
  archived      Boolean   @default(false) // true = Kindle 側で削除されたが、アプリ側のメモ等を残すために保持
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Spaced repetition (SM-2 簡易版) フィールド
  reviewInterval Int     @default(0)    // 次回までの日数 (0=未学習)
  reviewEase     Float   @default(2.5)  // 易しさ係数 (SM-2 デフォルト 2.5、最低 1.3)
  reviewReps     Int     @default(0)    // 連続成功回数
  nextReviewAt   DateTime? @db.Date     // 次回復習日 (null=未スケジュール)
  lastReviewedAt DateTime?

  book    Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  reviews HighlightReview[]

  @@unique([bookId, externalId])
  @@index([bookId])
  @@index([nextReviewAt])
  @@index([archived])
}

// 復習履歴（1 ハイライトに複数件）
model HighlightReview {
  id          String   @id @default(cuid())
  highlightId String
  rating      Int      // 0=Forgot, 1=Hard, 2=Good, 3=Easy
  intervalDays Int     // この復習で次回までの日数として設定された値
  reviewedAt  DateTime @default(now())

  highlight Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@index([highlightId])
  @@index([reviewedAt])
}

// しおり
model Bookmark {
  id           String    @id @default(cuid())
  bookId       String
  location     String?
  page         Int?
  bookmarkedAt DateTime?
  externalId   String?
  archived     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, externalId])
  @@index([bookId])
  @@index([archived])
}

// 読書記録
model ReadingLog {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  bookTitleId String? // 旧スキーマ参照（次PRで削除）
  bookId      String? // 新スキーマ参照（移行後に必須化）
  review      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookTitle BookTitle? @relation(fields: [bookTitleId], references: [id])
  book      Book?      @relation("BookReadingLogs", fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([date, bookTitleId])
  @@unique([date, bookId])
  @@index([bookId])
}

// 習慣マスタ
model Habit {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  level1    String   @default("")
  level2    String   @default("")
  level3    String   @default("")
  level4    String   @default("")
  level5    String   @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs HabitLog[]
}

// 習慣ログ
model HabitLog {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  habitId   String
  level     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id])

  @@unique([date, habitId])
}

// スマホロック解除イベント (iOS Shortcut から POST される)
model UnlockEvent {
  id        String   @id @default(cuid())
  timestamp DateTime
  source    String   @default("ios") // "ios" | "manual" | "web"
  createdAt DateTime @default(now())

  @@index([timestamp])
}

// 確定済み睡眠セッション (cleanup でUnlockEventから集約)
model SleepSession {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date // JST覚醒日
  sleepAt         DateTime
  wakeAt          DateTime
  durationMinutes Int
  createdAt       DateTime @default(now())
}
