generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// カテゴリ (事業A, 事業B, 全体, プライベート)
model Category {
  id                 String   @id @default(cuid())
  name               String
  excludeFromSummary Boolean  @default(false)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  timeEntries TimeEntry[]
}

// ジャンル (1on1, MTG, 開発, プロジェクト, 思考, 対話, ルーティン)
model Genre {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  type      String   @default("経費")
  subType   String   @default("")          // "投資的" | "経費的" | ""(付随)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries TimeEntry[]
}

// 時間記録
model TimeEntry {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  startSlot  Int      // 0-47 (30分刻み、0=0:00, 1=0:30, ...)
  endSlot    Int      // 0-47 (開始の次以降)
  categoryId String
  genreId    String
  title      String?
  detail     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 繰り返し設定（親エントリのみ）
  recurrenceRule String?   // JSON: { type, interval?, customUnit?, daysOfWeek? }
  recurrenceEnd  DateTime? @db.Date

  // オーバーライド/例外（子エントリのみ）
  parentRecurrenceId String?
  originalDate       DateTime? @db.Date // 本来の発生日
  skipped            Boolean   @default(false) // true = この回はキャンセル

  category         Category   @relation(fields: [categoryId], references: [id])
  genre            Genre      @relation(fields: [genreId], references: [id])
  parentRecurrence TimeEntry? @relation("RecurrenceOverrides", fields: [parentRecurrenceId], references: [id])
  overrides        TimeEntry[] @relation("RecurrenceOverrides")
}

// 家計簿カテゴリ
model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6b7280")
  icon      String   @default("default")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses      Expense[]
  fixedExpenses FixedExpense[]
}

// 家計簿
model Expense {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  amount     Int
  type       String   @default("expense") // "expense" or "income"
  categoryId String?
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

// 固定費
model FixedExpense {
  id         String   @id @default(cuid())
  title      String
  amount     Int
  type       String   @default("expense") // "expense" or "income"
  categoryId String?
  day        Int      @default(1) // 毎月の引落日
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

// 一言日記
model DailyNote {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 筋トレメニューマスタ
model ExerciseMenu {
  id            String   @id @default(cuid())
  name          String
  defaultWeight String   @default("")
  defaultReps   Int      @default(10)
  defaultSets   Int      @default(3)
  type          String   @default("strength") // "strength" | "running"
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 筋トレ記録
model WorkoutLog {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  exercises Json     // [{menuId?, name, weight, reps, sets, type, distance?, duration?, pace?}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 本マスタ
model BookTitle {
  id        String   @id @default(cuid())
  title     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readingLogs ReadingLog[]
}

// 読書記録
model ReadingLog {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  bookTitleId String
  review      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookTitle BookTitle @relation(fields: [bookTitleId], references: [id])

  @@unique([date, bookTitleId])
}

// 習慣マスタ
model Habit {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  level1    String   @default("")
  level2    String   @default("")
  level3    String   @default("")
  level4    String   @default("")
  level5    String   @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs HabitLog[]
}

// 習慣ログ
model HabitLog {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  habitId   String
  level     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id])

  @@unique([date, habitId])
}

// スマホロック解除イベント (iOS Shortcut から POST される)
model UnlockEvent {
  id        String   @id @default(cuid())
  timestamp DateTime
  source    String   @default("ios") // "ios" | "manual" | "web"
  createdAt DateTime @default(now())

  @@index([timestamp])
}

// 確定済み睡眠セッション (cleanup でUnlockEventから集約)
model SleepSession {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date // JST覚醒日
  sleepAt         DateTime
  wakeAt          DateTime
  durationMinutes Int
  createdAt       DateTime @default(now())
}
