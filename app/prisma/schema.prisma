generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// カテゴリ (事業A, 事業B, 全体, プライベート)
model Category {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries TimeEntry[]
}

// ジャンル (1on1, MTG, 開発, プロジェクト, 思考, 対話, ルーティン)
model Genre {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  type      String   @default("経費")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries TimeEntry[]
}

// 時間記録
model TimeEntry {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  startSlot  Int      // 0-47 (30分刻み、0=0:00, 1=0:30, ...)
  endSlot    Int      // 0-47 (開始の次以降)
  categoryId String
  genreId    String
  title      String?
  detail     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  genre    Genre    @relation(fields: [genreId], references: [id])
}

// 家計簿カテゴリ
model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6b7280")
  icon      String   @default("default")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses      Expense[]
  fixedExpenses FixedExpense[]
}

// 家計簿
model Expense {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  amount     Int
  type       String   @default("expense") // "expense" or "income"
  categoryId String?
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

// 固定費
model FixedExpense {
  id         String   @id @default(cuid())
  title      String
  amount     Int
  type       String   @default("expense") // "expense" or "income"
  categoryId String?
  day        Int      @default(1) // 毎月の引落日
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

// 一言日記
model DailyNote {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
